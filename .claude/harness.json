{
  "language": "python+typescript",
  "framework": "fastapi+react",
  "packageManager": "pip+npm",
  "typecheck": {
    "command": "npx tsc --noEmit",
    "perFile": true
  },
  "test": {
    "command": null,
    "framework": null
  },
  "qualityRules": {
    "builtIn": [
      "no-confirm-alert",
      "no-transition-all"
    ],
    "custom": [
      {
        "name": "auto-session4-no-silent-build",
        "pattern": "2>/dev/null.*\\|\\|.*echo.*WARN",
        "filePattern": "**/Dockerfile",
        "message": "Learned from session 4: Silent build failures hide missing tools. Let builds fail loudly or check at runtime with which."
      },
      {
        "name": "auto-session4-pydantic-schema-sync",
        "pattern": "class.*Response.*BaseModel",
        "filePattern": "backend/app/schemas/*.py",
        "message": "Learned from session 4: Verify Pydantic response schemas include all ORM model fields. Missing extracted_path hid the action buttons."
      },
      {
        "name": "auto-session5-no-scalar-one-or-none-on-fk",
        "pattern": "scalar_one_or_none\\(\\)",
        "filePattern": "backend/app/routers/*.py",
        "message": "Learned from session 5: scalar_one_or_none() crashes with MultipleResultsFound on one-to-many relations. Use .order_by().limit(1) or .all() instead."
      },
      {
        "name": "auto-session5-yara-no-unreferenced-strings",
        "pattern": "strings:",
        "filePattern": "**/*.yar",
        "message": "Learned from session 5: Every YARA string must appear in the condition. Unreferenced strings cause compilation errors."
      }
    ]
  },
  "protectedFiles": [
    ".claude/harness.json"
  ],
  "features": {
    "intakeScanner": true,
    "telemetry": true
  },
